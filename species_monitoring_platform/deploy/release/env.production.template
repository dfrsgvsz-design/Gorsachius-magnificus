# ─────────────────────────────────────────────────────────────────────────────
# Production .env template — Gorsachius magnificus field survey backend
# Copy to the server as `.env` next to docker-compose.yml (or /opt/gm-backend/.env
# for the systemd layout) and fill every <PLACEHOLDER>.
#
# Hard rules (B13 lesson):
#   * CORS_ORIGINS and the APK's VITE_API_BASE_URL must be https:// — never http.
#   * In mainland China the public hostname must be an ICP-registered domain.
# ─────────────────────────────────────────────────────────────────────────────

APP_PORT=8000
WEB_CONCURRENCY=1

# Public origins allowed to call the API. Include the app origin(s) only.
# Capacitor Android WebView origin is https://localhost (keep it listed).
CORS_ORIGINS=https://<api.your-icp-domain.cn>,https://localhost

# Inbound API key for general API protection (optional but recommended).
# Clients must send X-API-Key (or Authorization: Bearer <key>).
BIRD_API_KEY=<GENERATE: openssl rand -hex 32>
XC_API_KEY=

# REQUIRED (B19): admin token guard for DELETE/restore endpoints.
# Set ADMIN_PIN to the exact 4-12 digit PIN the field lead configures in the
# app's AdminGate. The app derives X-Admin-Token from this PIN after unlock.
ADMIN_PIN=<SAME PIN AS DEVICE ADMINGATE>
ADMIN_API_TOKEN=

# Soft-delete trash GC (B21). Purged rows are archived as JSONL under
# <survey_store>/trash_archive/ before hard deletion.
SURVEY_TRASH_GC_ENABLED=1
SURVEY_TRASH_RETENTION_DAYS=30
SURVEY_TRASH_GC_INTERVAL_HOURS=24

# Crash/error monitoring (optional; requires `pip install sentry-sdk`).
SENTRY_DSN=
DEPLOY_ENV=production

# ── Docker-compose layout only ───────────────────────────────────────────────
BSP_APP_DATA_DIR=./deploy/pilot/volumes/app-data
BSP_BACKEND_DATA_DIR=./deploy/pilot/volumes/backend-data
BSP_CONFIG_DIR=./deploy/pilot/volumes/config
BSP_LOG_DIR=./deploy/pilot/volumes/logs
BSP_CHECKPOINTS_DIR=./backend/checkpoints
BSP_HEALTH_TIMEOUT=180
BSP_BACKUP_DIR=./deploy/pilot/backups

# ── Post-deploy verification (run from any external machine) ────────────────
#   curl https://<api-host>/api/health            → status ok / healthy
#   curl https://<api-host>/api/health/readiness  → ready true
#   curl -X POST https://<api-host>/api/surveys/sync/push ...   (with API key)
#   DELETE without X-Admin-Token must return 401.
