# Local development and CI defaults only.
# Do not use these values directly for a controlled go-live deployment.
APP_PORT=8000
WEB_CONCURRENCY=1
CORS_ORIGINS=http://localhost:8000

# Optional API keys
BIRD_API_KEY=
XC_API_KEY=

# Admin token auth for DELETE/restore endpoints (B19).
# Set ADMIN_PIN to the same 4-12 digit PIN the field lead configures in the
# app's AdminGate; the X-Admin-Token header is derived from it on both sides.
# ADMIN_API_TOKEN (a literal token) takes precedence when set. Leave both
# empty in local dev to keep the endpoints open.
ADMIN_PIN=
ADMIN_API_TOKEN=

# Soft-delete trash GC (B21): hard-delete tombstoned rows after N days.
SURVEY_TRASH_GC_ENABLED=1
SURVEY_TRASH_RETENTION_DAYS=30
SURVEY_TRASH_GC_INTERVAL_HOURS=24

# Optional crash/error monitoring (requires `pip install sentry-sdk`)
SENTRY_DSN=

# Writable host directories backed up by the helper scripts
BSP_APP_DATA_DIR=./deploy/pilot/volumes/app-data
BSP_BACKEND_DATA_DIR=./deploy/pilot/volumes/backend-data
BSP_CONFIG_DIR=./deploy/pilot/volumes/config
BSP_LOG_DIR=./deploy/pilot/volumes/logs

# Repo-managed model assets mounted read-only into the container
BSP_CHECKPOINTS_DIR=./backend/checkpoints

# Optional field operator tuning
BSP_HEALTH_TIMEOUT=180
BSP_BACKUP_DIR=./deploy/pilot/backups
