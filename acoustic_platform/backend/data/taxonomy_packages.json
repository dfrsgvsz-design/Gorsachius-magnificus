    "supported_name_fields": [
      "scientific_name",
      "simplified_chinese_name",
      "traditional_chinese_name",
      "english_common_name",
      "synonyms"
    ],
    "shared_taxon_key": "internal_taxon_id",
    "jurisdictional_status_fields": [
      "national_protection_status",
      "red_list_status",
      "sensitive_coordinate_policy"
    ]
  },
