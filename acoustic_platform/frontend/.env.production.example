# Production build variables for Android/iOS native packages.
# Required on native builds: must be absolute HTTPS origin.
# Example: VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=

# Optional feature toggle for pilot-only deployment.
# true: show pilot mode banner/behavior if supported by app.
# false: normal production behavior.
VITE_PILOT_MODE=false
