# Optional absolute backend base for native Capacitor builds.
# Leave blank for web/PWA so the frontend keeps using relative /api and /ws.
# For a controlled go-live Android build, set this to the real field server origin.
#
# Accepted examples:
# VITE_API_BASE_URL=https://field.internal.example
# VITE_API_BASE_URL=https://field.internal.example/api
# VITE_API_BASE_URL=https://survey.internal.example/field
VITE_API_BASE_URL=
