# backend/data/ : top-level JSON files are contract assets (survey_protocols,
# taxonomy_packages, china_birds, vertebrate_export_profiles, platform_config,
# survey_sites, *_taxonomy_seed) — REQUIRED by tests + runtime, tracked in git.
# Only mutable runtime subdirectories (detections/, images/, survey_store/,
# taxonomy_releases/, taxonomy_sources/, fewshot_detectors/,
# training_datasets/) are ignored.
backend/data/*/

# Top-level data/ (model artifacts, generic mutable state) stays ignored.
/data/
